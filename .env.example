# ====================================================================
# קובץ דוגמה למשתני סביבה — the-5-agents
# העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
# הקובץ .env עצמו לא נשמר ב-git (ראה .gitignore).
# ====================================================================

# כאן יתווספו בהמשך מפתחות ה-API והגדרות הסביבה של הצוות.
# דוגמאות אפשריות (כרגע מושבתות):
#
# ANTHROPIC_API_KEY=          # להפעלת הסוכנים (יעל / יובל / חן)
# GEMINI_API_KEY=             # ליצירת תמונות (יובל)
# TAVILY_API_KEY=             # למחקר וחיפוש ברשת (חן)
